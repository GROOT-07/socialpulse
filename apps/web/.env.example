# ── API Connection ────────────────────────────────────────────
# Base URL of your deployed API (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── App URL ───────────────────────────────────────────────────
# Full public URL of this web app — used for OAuth redirects, emails, etc.
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change-me-32-chars-minimum-random-secret
NEXTAUTH_URL=https://app.yourdomain.com
