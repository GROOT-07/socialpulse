// SocialPulse — Prisma Schema v1.0
// Generated per MASTER_PROMPT.md Part 3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  VIEWER
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  WHATSAPP
  GOOGLE
}

enum ContentFormat {
  REEL
  CAROUSEL
  STORY
  POST
  SHORT
  VIDEO
}

enum PostStatus {
  PLANNED
  PUBLISHED
  SKIPPED
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  MISSED
}

enum IdeaStatus {
  BACKLOG
  SCHEDULED
  DONE
}

enum Priority {
  MUST
  HIGH
  MEDIUM
}

enum PlaybookSectionType {
  BRAND_VOICE
  STRATEGY
  POSTING_GUIDE
  OUTREACH
  ORG_SUMMARY
}

enum KeywordCategory {
  QUICK_WIN
  MEDIUM
  LONG_TERM
  LOCAL
}

enum ContentPieceType {
  POST
  REEL_SCRIPT
  BLOG
  ARTICLE
  VIDEO_SCRIPT
  FAQ
  LANDING_PAGE
  GOOGLE_POST
}

enum ContentPieceStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum SpecialDayCategory {
  NATIONAL_HOLIDAY
  RELIGIOUS
  INDUSTRY
  INTERNATIONAL
  AUSPICIOUS
}

enum CompetitorStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

enum CompetitorSource {
  GOOGLE_LOCAL
  GOOGLE_MAPS
  SOCIAL_DISCOVERY
  SEO_COMPETITOR
  MANUAL
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ORG_ADMIN)
  activeOrgId  String?

  // Relations
  ownedOrgs      Organization[] @relation("OrgOwner")
  orgMemberships OrgMember[]
  refreshTokens  RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Organization {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  logoUrl          String?
  brandColor       String?    @default("#4F6EF7")
  industry         String
  city             String?
  country          String?
  timezone         String     @default("UTC")
  activePlatforms  Platform[]
  ownerId          String
  owner            User       @relation("OrgOwner", fields: [ownerId], references: [id])

  // New v2 fields
  website          String?
  businessType     String?          // LOCAL | REGIONAL | NATIONAL | GLOBAL
  language         String           @default("English")

  // Relations
  members          OrgMember[]
  socialAccounts   SocialAccount[]
  competitors      Competitor[]
  contentCalendar  ContentCalendar[]
  goals            Goal[]
  personas         Persona[]
  contentPillars   ContentPillar[]
  checklistItems   ChecklistItem[]
  auditItems       AuditItem[]
  ideas            Idea[]
  playbookSections PlaybookSection[]
  dailyBriefs      DailyBrief[]
  voiceProfile     BrandVoice?
  keywordOpportunities KeywordOpportunity[]
  contentPieces    ContentPiece[]
  orgIntelligence  OrgIntelligence?
  trendingTopics   TrendingTopic[]
  sprintPlans      SprintPlan[]
  guardrails       ContentGuardrail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model OrgMember {
  id     String   @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   UserRole     @default(VIEWER)

  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  @@unique([orgId, userId])
  @@map("org_members")
}

model SocialAccount {
  id             String    @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  platform       Platform
  handle         String?
  profileUrl     String?
  // Encrypted with AES-256 (ENCRYPTION_KEY env var)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  connectedAt    DateTime  @default(now())

  metrics SocialMetrics[]

  @@unique([orgId, platform])
  @@map("social_accounts")
}

model SocialMetrics {
  id              String        @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  snapshotDate    DateTime      @db.Date
  followers       Int           @default(0)
  following       Int           @default(0)
  posts           Int           @default(0)
  engagementRate  Float         @default(0)
  reach           Int           @default(0)
  impressions     Int           @default(0)
  avgLikes        Float         @default(0)
  avgComments     Float         @default(0)
  rawJson         Json?

  createdAt DateTime @default(now())

  @@unique([socialAccountId, snapshotDate])
  @@map("social_metrics")
}

model Competitor {
  id               String           @id @default(cuid())
  orgId            String
  org              Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  platform         Platform
  handle           String
  profileUrl       String?
  businessName     String?
  logoUrl          String?
  address          String?
  city             String?
  website          String?
  relevanceScore   Int              @default(0) // 0-100, AI-assigned
  status           CompetitorStatus @default(PENDING)
  source           CompetitorSource @default(GOOGLE_LOCAL)
  discoveryReason  String?          // AI explanation of why this is a competitor
  addedAt          DateTime         @default(now())

  metrics    CompetitorMetrics[]
  posts      CompetitorPost[]

  @@unique([orgId, platform, handle])
  @@map("competitors")
}

model CompetitorMetrics {
  id             String     @id @default(cuid())
  competitorId   String
  competitor     Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  snapshotDate   DateTime   @db.Date
  followers      Int        @default(0)
  engagementRate Float      @default(0)
  avgLikes       Float      @default(0)
  avgComments    Float      @default(0)
  topPostUrl     String?
  topPostLikes   Int        @default(0)
  rawJson        Json?

  createdAt DateTime @default(now())

  @@unique([competitorId, snapshotDate])
  @@map("competitor_metrics")
}

model ContentCalendar {
  id           String        @id @default(cuid())
  orgId        String
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  date         DateTime      @db.Date
  time         String?       // "14:30" 24h format
  platform     Platform
  topic        String
  contentPillar String?
  format       ContentFormat @default(POST)
  caption      String?
  notes        String?
  status       PostStatus    @default(PLANNED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_calendar")
}

model Goal {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  platform     Platform?
  metric       String       // "followers", "engagementRate", etc.
  targetValue  Float
  currentValue Float        @default(0)
  unit         String       @default("")
  dueDate      DateTime?
  status       GoalStatus   @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("goals")
}

model Persona {
  id                String       @id @default(cuid())
  orgId             String
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name              String
  ageRange          String?
  gender            String?
  location          String?
  interests         String[]
  platforms         Platform[]
  painPoints        String[]
  contentPreference String?
  aiGenerated       Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("personas")
}

model BrandVoice {
  id           String       @id @default(cuid())
  orgId        String       @unique
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  adjectives   String[]     // 5 voice adjectives
  personality  String?      // e.g. "The Helpful Expert"
  dos          String[]     // Do's
  donts        String[]     // Don'ts
  toneByPlatform Json?      // { INSTAGRAM: "...", FACEBOOK: "..." }
  captionGood  String?
  captionBad   String?
  aiGenerated  Boolean      @default(false)

  updatedAt DateTime @updatedAt

  @@map("brand_voice")
}

model ContentPillar {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  colorHex        String       @default("#4F6EF7")
  postingRatio    Int          @default(20) // percentage 0-100
  exampleFormats  String[]
  captionStarters String[]

  ideas Idea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_pillars")
}

model ChecklistItem {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  platform    Platform
  title       String
  description String?
  priority    Priority     @default(MEDIUM)
  isDone      Boolean      @default(false)
  doneAt      DateTime?
  isCustom    Boolean      @default(false)

  createdAt DateTime @default(now())

  @@map("checklist_items")
}

model AuditItem {
  id       String       @id @default(cuid())
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  platform Platform
  category String
  title    String
  isDone   Boolean      @default(false)
  score    Int          @default(0) // 0-100

  @@map("audit_items")
}

model Idea {
  id          String        @id @default(cuid())
  orgId       String
  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title       String
  description String?
  platform    Platform?
  pillarId    String?
  pillar      ContentPillar? @relation(fields: [pillarId], references: [id])
  captionStarter String?
  status      IdeaStatus    @default(BACKLOG)
  aiGenerated Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ideas")
}

model PlaybookSection {
  id             String              @id @default(cuid())
  orgId          String
  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sectionType    PlaybookSectionType
  content        Json
  generatedByAI  Boolean             @default(false)

  updatedAt DateTime @updatedAt

  @@unique([orgId, sectionType])
  @@map("playbook_sections")
}

model DailyBrief {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  summary        String
  pendingTasks   Json         @default("[]")
  scheduledPosts Json         @default("[]")
  ideaOfDay      String?
  competitorPulse Json?
  generatedAt    DateTime     @default(now())

  @@unique([orgId, date])
  @@map("daily_briefs")
}

// ── New V2 Models ──────────────────────────────────────────────

model KeywordOpportunity {
  id               String          @id @default(cuid())
  orgId            String
  org              Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keyword          String
  searchVolume     Int             @default(0)
  difficulty       Int             @default(50) // 1-100
  currentRank      Int?            // null = not ranking
  competitorDomain String?
  competitorRank   Int?
  targetRank       Int             @default(1)
  category         KeywordCategory @default(MEDIUM)
  contentCreated   Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([orgId, keyword])
  @@map("keyword_opportunities")
}

model ContentPiece {
  id               String             @id @default(cuid())
  orgId            String
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type             ContentPieceType
  platform         Platform?
  title            String
  content          String             @db.Text
  hashtags         String[]
  seoScore         Int                @default(0) // 0-100
  keywordTargeted  String?
  status           ContentPieceStatus @default(DRAFT)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  externalUrl      String?
  generatedByAI    Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("content_pieces")
}

model OrgIntelligence {
  id                      String       @id @default(cuid())
  orgId                   String       @unique
  org                     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  googleKgData            Json?
  googlePlacesData        Json?
  websiteMetaData         Json?
  detectedKeywords        String[]
  presenceScore           Int          @default(0) // 0-100
  presenceScoreBreakdown  Json?
  strengths               String[]
  urgentIssues            Json?        // array of {issue, actionLink}
  quickWins               Json?        // array of {action, impact}
  aiDiagnosis             Json?
  lastScannedAt           DateTime?
  createdAt               DateTime     @default(now())

  @@map("org_intelligence")
}

model SpecialDay {
  id                String           @id @default(cuid())
  name              String
  date              DateTime         @db.Date
  category          SpecialDayCategory
  countries         String[]
  industries        String[]         // empty = all industries
  draftPostTemplate String?          @db.Text
  createdAt         DateTime         @default(now())

  @@unique([name, date])
  @@map("special_days")
}

model TrendingTopic {
  id                  String       @id @default(cuid())
  orgId               String
  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  topic               String
  category            String
  searchVolume        Int          @default(0)
  trendDelta          Float        @default(0) // % change
  competitorsCovering Int          @default(0)
  suggestedPostDraft  String?      @db.Text
  platform            Platform?
  fetchedAt           DateTime     @default(now())

  @@map("trending_topics")
}

model CompetitorPost {
  id             String       @id @default(cuid())
  competitorId   String
  competitor     Competitor   @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  platform       Platform
  postUrl        String?
  caption        String?      @db.Text
  likesCount     Int          @default(0)
  commentsCount  Int          @default(0)
  sharesCount    Int          @default(0)
  engagementRate Float        @default(0)
  postedAt       DateTime?
  contentType    String?      // IMAGE | VIDEO | REEL | CAROUSEL
  hashtags       String[]
  fetchedAt      DateTime     @default(now())

  @@map("competitor_posts")
}

model SprintPlan {
  id          String      @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  status      String      @default("GENERATING") // GENERATING | READY | ARCHIVED
  weeks       SprintWeek[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([orgId])
  @@map("sprint_plans")
}

model SprintWeek {
  id          String    @id @default(cuid())
  sprintId    String
  sprint      SprintPlan @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  weekNumber  Int       // 1-8
  theme       String
  whyNow      String
  notableDates String[] // array of date strings
  platforms   Json      // Record<string, { hook, points, caption, hashtags }>
  createdAt   DateTime  @default(now())

  @@index([sprintId])
  @@map("sprint_weeks")
}

model ContentGuardrail {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category    String   // VOICE | LEGAL | PLATFORM | CONTENT | CULTURAL
  ruleType    String   // DO | DONT | RULE | WARNING
  text        String
  platform    String?  // null = all platforms
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@map("content_guardrails")
}
