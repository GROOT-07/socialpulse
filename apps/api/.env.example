# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────
# Redis URL for BullMQ job queues (Upstash, Redis Cloud, or self-hosted)
# Use rediss:// for TLS (required for Upstash)
REDIS_URL=rediss://default:password@host:6379

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-32-chars-minimum-random-secret
JWT_REFRESH_SECRET=change-me-32-chars-minimum-random-secret-refresh

# ── Encryption ────────────────────────────────────────────────
# Exactly 32 characters — used for encrypting social OAuth tokens at rest
ENCRYPTION_KEY=change-me-exactly-32-chars-padded

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# Public URL of your deployed API (no trailing slash)
API_BASE_URL=https://api.yourdomain.com

# Public URL of your deployed web app — used for CORS
# For multiple origins, use comma-separated values:
# CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
# CORS_ORIGINS=https://app.yourdomain.com

# ── Meta / Facebook / Instagram ───────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ── Google / YouTube ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── AI — Google Gemini ────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Optional: override default model names
# GEMINI_PRO_MODEL=gemini-2.5-pro
# GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Email / SMTP ──────────────────────────────────────────────
# Required for password-reset emails.
# Gmail: host=smtp.gmail.com  port=587  user=you@gmail.com  pass=<16-char app password>
# Resend: host=smtp.resend.com  port=465  user=resend  pass=<api-key>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="SocialPulse <no-reply@example.com>"

# ── Competitor Data ───────────────────────────────────────────
# Optional — Data365 API key for competitor analytics
DATA365_API_KEY=your-data365-api-key

# ── Search & SEO Intelligence (MODIFICATIONS V2) ─────────────
# SerpAPI — competitor discovery, keyword tracking, trending content
# Sign up at: https://serpapi.com
SERPAPI_KEY=your-serpapi-key

# Google Knowledge Graph API — auto-fetch org info on registration
# Enable at: https